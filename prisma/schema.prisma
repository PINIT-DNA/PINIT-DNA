generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model DnaRecord {
  id                    String             @id @default(uuid())
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  imageFilename         String
  imageMimeType         String
  imageSizeBytes        Int
  imageWidthPx          Int?
  imageHeightPx         Int?
  fileType              String?
  engineVersion         String?
  universalFingerprints Json?
  sha256Hash            String?
  schemaVersion         String             @default("1.0.0")
  status                DnaStatus          @default(PENDING)
  ownerUserId           String?
  behavioralLayer       BehavioralLayer?
  cryptoLayer           CryptoLayer?
  ownerUser             User?              @relation(fields: [ownerUserId], references: [id])
  lineageFrom           DocumentLineage[]  @relation("LineageFrom")
  lineageTo             DocumentLineage[]  @relation("LineageTo")
  evolutionLayer        EvolutionLayer?
  metadataLayer         MetadataLayer?
  monitorRecords        MonitorRecord[]
  ocrRecord             OcrRecord?
  originLayer           OriginLayer?
  perceptualLayer       PerceptualLayer?
  relationshipLayer     RelationshipLayer?
  semanticLayer         SemanticLayer?
  stegoLayer            StegoLayer?
  structuralLayer       StructuralLayer?
  vaultRecord           VaultRecord?
  verifications         VerificationLog[]

  // Layers 11-15
  deepfakeLayer         DeepfakeLayer?
  dctWatermarkLayer     DctWatermarkLayer?
  custodyLayer          CustodyLayer?
  zkProofLayer          ZkProofLayer?
  biometricBindLayer    BiometricBindLayer?

  @@map("dna_records")
}

// ── Layer 11: AI Deepfake Detection ──────────────────────────────────────────
model DeepfakeLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  deepfakeScore    Float     @default(0)
  isDeepfake       Boolean   @default(false)
  confidence       Float     @default(0)
  modelVersion     String    @default("1.0")
  analysisMethod   String    @default("pixel-noise-analysis")
  metadata         Json?
  flagged          Boolean   @default(false)
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("deepfake_layers")
}

// ── Layer 12: Invisible DCT Watermark ────────────────────────────────────────
model DctWatermarkLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  watermarkHash    String
  ownerIdEncoded   String
  timestamp        DateTime  @default(now())
  method           String    @default("dct-frequency")
  strength         Float     @default(0.85)
  embedded         Boolean   @default(false)
  survivalScore    Float     @default(0)
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("dct_watermark_layers")
}

// ── Layer 13: Legal Chain of Custody ─────────────────────────────────────────
model CustodyLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  custodyChain     Json      @default("[]")
  dmcaReady        Boolean   @default(true)
  evidenceHash     String?
  legalTimestamp   DateTime  @default(now())
  jurisdiction     String    @default("IN")
  courtAdmissible  Boolean   @default(true)
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("custody_layers")
}

// ── Layer 14: Zero-Knowledge Ownership Proof ─────────────────────────────────
model ZkProofLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  commitmentHash   String
  proofData        String
  publicKey        String
  verified         Boolean   @default(false)
  proofType        String    @default("hash-commitment")
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("zk_proof_layers")
}

// ── Layer 15: Biometric Identity Bind ────────────────────────────────────────
model BiometricBindLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  biometricHash    String
  biometricType    String    @default("face-embedding")
  bindMethod       String    @default("hmac-sha256")
  userId           String
  deviceInfo       String?
  embeddedInFile   Boolean   @default(false)
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("biometric_bind_layers")
}

model CryptoLayer {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  dnaRecordId    String    @unique
  sha256Hash     String    @db.Char(64)
  normalizedHash String    @db.Char(64)
  blake3Hash     String?   @db.Char(64)
  dnaRecord      DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("crypto_layers")
}

model StructuralLayer {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  dnaRecordId     String    @unique
  edgeMapB64      String
  edgeVectors     Json
  edgeSignature64 String    @db.Char(16)
  algorithm       String    @default("canny")
  dnaRecord       DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("structural_layers")
}

model PerceptualLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  dnaRecordId String    @unique
  pHash64     String    @db.Char(16)
  pHash256    String    @db.Char(64)
  aHash64     String    @db.Char(16)
  dHash64     String    @db.Char(16)
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("perceptual_layers")
}

model SemanticLayer {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String    @unique
  histogramR       Json
  histogramG       Json
  histogramB       Json
  histogramH       Json
  histogramS       Json
  dominantColors   Json
  colorFingerprint String    @db.Char(12)
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("semantic_layers")
}

model MetadataLayer {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  dnaRecordId  String    @unique
  exifData     Json?
  deviceMake   String?
  deviceModel  String?
  software     String?
  capturedAt   DateTime?
  gpsLatitude  Float?
  gpsLongitude Float?
  iptcData     Json?
  xmpData      Json?
  metadataHash String    @db.Char(64)
  dnaRecord    DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("metadata_layers")
}

model StegoLayer {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  dnaRecordId  String    @unique
  embedded     Boolean   @default(false)
  capacityBits Int?
  usedBits     Int?
  payloadHmac  String    @db.Char(64)
  channel      String    @default("B")
  carrierPath  String?
  dnaRecord    DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("stego_layers")
}

model BehavioralLayer {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  dnaRecordId  String    @unique
  behaviorHash String
  uploadMs     Int
  sessionToken String?
  userAgent    String?
  processingMs Int       @default(0)
  dnaRecord    DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("behavioral_layers")
}

model RelationshipLayer {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  dnaRecordId   String    @unique
  graphHash     String?
  relatedIds    String[]
  relationTypes String[]
  processingMs  Int       @default(0)
  dnaRecord     DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("relationship_layers")
}

model OriginLayer {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  dnaRecordId  String    @unique
  originBundle Json
  bundleHash   String
  processingMs Int       @default(0)
  dnaRecord    DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("origin_layers")
}

model EvolutionLayer {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  dnaRecordId  String    @unique
  merkleRoot   String?
  mutationLog  Json      @default("[]")
  version      Int       @default(1)
  processingMs Int       @default(0)
  dnaRecord    DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("evolution_layers")
}

model VerificationLog {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  dnaRecordId      String
  passed           Boolean
  layerResults     Json
  similarityScores Json
  confidenceScore  Float
  layersChecked    String[]
  requestIp        String?
  dnaRecord        DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("verification_logs")
}

model VaultRecord {
  id                  String    @id @default(uuid())
  createdAt           DateTime  @default(now())
  dnaRecordId         String    @unique
  encryptedFilePath   String
  originalFileName    String
  originalMimeType    String
  encryptedSizeBytes  Int
  originalSizeBytes   Int
  encryptionAlgorithm String    @default("AES-256-GCM")
  keyDerivation       String    @default("HKDF-SHA256")
  ivHex               String    @db.Char(24)
  authTagHex          String    @db.Char(32)
  dnaRecord           DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("vault_records")
}

model User {
  id                 String           @id @default(uuid())
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  shortId            String           @unique
  email              String?          @unique
  passwordHash       String?
  fullName           String           @default("PINIT User")
  role               UserRole         @default(USER)
  isActive           Boolean          @default(true)
  lastLoginAt        DateTime?
  avatarUrl          String?
  bio                String?
  country            String?
  jobTitle           String?
  notifyCertificates Boolean          @default(true)
  notifyMonitoring   Boolean          @default(true)
  notifyRiskAlerts   Boolean          @default(true)
  notifyShareAccess  Boolean          @default(true)
  notifyUpdates      Boolean          @default(false)
  organization       String?
  phone              String?
  theme              String           @default("light")

  // Face Recognition Auth
  faceEmbedding      Float[]          @default([])
  faceRegistered     Boolean          @default(false)
  faceRegisteredAt   DateTime?
  voiceEmbedding     Float[]          @default([])
  voiceRegistered    Boolean          @default(false)
  webauthnCredentialId String?
  deviceFingerprint  String?
  authMethod         String           @default("password")

  certificates       Certificate[]
  dnaRecords         DnaRecord[]
  evidenceRecords    EvidenceRecord[]
  loginHistory       LoginHistory[]
  monitorRecords     MonitorRecord[]
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  shareLinks         ShareLink[]
  shareRecipients    ShareRecipient[]

  @@map("users")
}

model LoginHistory {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  userId      String
  method      String   @default("face")
  ip          String?
  userAgent   String?
  device      String?
  browser     String?
  os          String?
  city        String?
  country     String?
  success     Boolean  @default(true)
  failReason  String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  type      String
  title     String
  body      String
  severity  String   @default("info")
  read      Boolean  @default(false)
  linkToken String?
  fileName  String?
  ip        String?
  country   String?
  device    String?
  riskLevel String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Certificate {
  id               String     @id @default(uuid())
  createdAt        DateTime   @default(now())
  certificateId    String     @unique
  dnaRecordId      String
  vaultId          String
  status           CertStatus @default(ACTIVE)
  signature        String
  issuedAt         DateTime   @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  issuedByUserId   String?
  ownerUserId      String?
  ownerUser        User?      @relation(fields: [ownerUserId], references: [id])

  @@index([dnaRecordId])
  @@index([vaultId])
  @@map("certificates")
}

model OcrRecord {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  dnaRecordId   String    @unique
  extractedText String?
  wordCount     Int       @default(0)
  confidence    Float     @default(0)
  language      String    @default("eng")
  processingMs  Int       @default(0)
  indexed       Boolean   @default(false)
  ocrStatus     String    @default("PENDING")
  errorMessage  String?
  dnaRecord     DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  @@map("ocr_records")
}

model DocumentLineage {
  id              String    @id @default(uuid())
  createdAt       DateTime  @default(now())
  fromDnaRecordId String
  toDnaRecordId   String
  relation        String
  confidence      Float
  fromDnaRecord   DnaRecord @relation("LineageFrom", fields: [fromDnaRecordId], references: [id], onDelete: Cascade)
  toDnaRecord     DnaRecord @relation("LineageTo", fields: [toDnaRecordId], references: [id], onDelete: Cascade)

  @@unique([fromDnaRecordId, toDnaRecordId])
  @@map("document_lineage")
}

model AuditEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  eventType   String
  userId      String?
  dnaRecordId String?
  vaultId     String?
  filename    String?
  fileType    String?
  ipAddress   String?
  userAgent   String?
  browser     String?
  os          String?
  device      String?
  detail      Json?

  @@index([dnaRecordId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_events")
}

model MonitorRecord {
  id             String          @id @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  dnaRecordId    String
  filename       String
  fileType       String          @default("UNKNOWN")
  status         String          @default("ACTIVE")
  checkEveryHrs  Int             @default(24)
  lastCheckedAt  DateTime?
  nextCheckAt    DateTime?
  totalChecks    Int             @default(0)
  totalMatches   Int             @default(0)
  watchUrls      String[]
  lastDurationMs Int?
  scanType       String          @default("DAILY")
  totalFailures  Int             @default(0)
  ownerUserId    String?
  crawlResults   CrawlResult[]
  dnaRecord      DnaRecord       @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)
  ownerUser      User?           @relation(fields: [ownerUserId], references: [id])
  monitoringRuns MonitoringRun[]

  @@index([status])
  @@index([nextCheckAt])
  @@map("monitor_records")
}

model CrawlResult {
  id                String        @id @default(uuid())
  createdAt         DateTime      @default(now())
  monitorRecordId   String
  url               String
  pageTitle         String?
  foundText         String?
  textLength        Int           @default(0)
  similarity        Float         @default(0)
  matchType         String        @default("NO_MATCH")
  alertStatus       String        @default("PENDING")
  checkedAt         DateTime      @default(now())
  contentSnapshot   String?
  evidenceGenerated Boolean       @default(false)
  screenshotPath    String?
  monitorRecord     MonitorRecord @relation(fields: [monitorRecordId], references: [id], onDelete: Cascade)

  @@index([monitorRecordId])
  @@index([matchType])
  @@index([alertStatus])
  @@map("crawl_results")
}

model MonitoringRun {
  id              String              @id @default(uuid())
  createdAt       DateTime            @default(now())
  monitorRecordId String
  status          String              @default("RUNNING")
  trigger         String              @default("SCHEDULED")
  startedAt       DateTime            @default(now())
  completedAt     DateTime?
  durationMs      Int?
  candidatesFound Int                 @default(0)
  matchesFound    Int                 @default(0)
  failureReason   String?
  failures        MonitoringFailure[]
  monitorRecord   MonitorRecord       @relation(fields: [monitorRecordId], references: [id], onDelete: Cascade)

  @@index([monitorRecordId])
  @@index([status])
  @@map("monitoring_runs")
}

model MonitoringFailure {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())
  monitoringRunId String
  url             String
  errorCode       String?
  errorMessage    String?
  stage           String?
  monitoringRun   MonitoringRun @relation(fields: [monitoringRunId], references: [id], onDelete: Cascade)

  @@index([monitoringRunId])
  @@map("monitoring_failures")
}

model ShareLink {
  id                        String             @id @default(uuid())
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  vaultId                   String
  dnaRecordId               String
  filename                  String
  mimeType                  String             @default("application/octet-stream")
  token                     String             @unique
  expiresAt                 DateTime?
  maxViews                  Int?
  viewCount                 Int                @default(0)
  isActive                  Boolean            @default(true)
  allowDownload             Boolean            @default(false)
  requireName               Boolean            @default(false)
  note                      String?
  oneTimeUse                Boolean            @default(false)
  maxDownloads              Int?
  downloadCount             Int                @default(0)
  allowedCountries          String[]           @default([])
  allowedDeviceTypes        String[]           @default([])
  allowedIpPrefixes         String[]           @default([])
  requireOtp                Boolean            @default(false)
  recipientEmail            String?
  otpCodeHash               String?
  otpExpiresAt              DateTime?
  otpVerified               Boolean            @default(false)
  tokenSignature            String?
  privacyMaskingEnabled     Boolean            @default(false)
  maskEmail                 Boolean            @default(false)
  maskPhone                 Boolean            @default(false)
  maskAadhaar               Boolean            @default(false)
  maskPan                   Boolean            @default(false)
  maskAddress               Boolean            @default(false)
  maskCustomPatterns        String?
  requestLocation           Boolean            @default(false)
  ownerUserId               String?
  depth                     Int                @default(0)
  forwardedByLabel          String?
  forwardingDetected        Boolean            @default(false)
  intendedDeviceFingerprint String?
  intendedIpAddress         String?
  linkType                  String             @default("PARENT")
  parentLinkId              String?
  recipientLabel            String?
  corporateIpRanges         String[]           @default([])
  domainRestrictions        String[]           @default([])
  firstViewExpiresAfter     Int?
  forwardConfidence         Int                @default(0)
  forwardRiskScore          Int                @default(0)
  forwardStatus             String             @default("CLEAN")
  oneDeviceOnly             Boolean            @default(false)
  oneIpOnly                 Boolean            @default(false)
  shareRecipientId          String?
  torBlock                  Boolean            @default(true)
  vpnBlock                  Boolean            @default(false)
  watermarkCode             String?
  forwardEvents             LinkForwardEvent[]
  accessLogs                ShareAccessLog[]
  ownerUser                 User?              @relation(fields: [ownerUserId], references: [id])
  parentLink                ShareLink?         @relation("LinkHierarchy", fields: [parentLinkId], references: [id])
  childLinks                ShareLink[]        @relation("LinkHierarchy")
  shareRecipient            ShareRecipient?    @relation(fields: [shareRecipientId], references: [id])
  unmaskRequests            UnmaskRequest[]

  @@index([token])
  @@index([vaultId])
  @@index([dnaRecordId])
  @@index([parentLinkId])
  @@index([shareRecipientId])
  @@index([forwardStatus])
  @@map("share_links")
}

model ShareRecipient {
  id               String                @id @default(uuid())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  ownerUserId      String
  label            String
  recipientCode    String                @unique
  trustScore       Int                   @default(100)
  knownDevices     String[]              @default([])
  knownIps         String[]              @default([])
  knownCountries   String[]              @default([])
  totalAccessCount Int                   @default(0)
  lastAccessAt     DateTime?
  firstAccessAt    DateTime?
  trustEvents      RecipientTrustEvent[]
  shareLinks       ShareLink[]
  ownerUser        User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([recipientCode])
  @@map("share_recipients")
}

model RecipientTrustEvent {
  id          String         @id @default(uuid())
  createdAt   DateTime       @default(now())
  recipientId String
  eventType   String
  scoreBefore Int
  scoreAfter  Int
  delta       Int
  reason      String
  linkId      String?
  recipient   ShareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@map("recipient_trust_events")
}

model UnmaskRequest {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  shareToken    String
  recipientName String?
  sessionId     String?
  ipAddress     String?
  device        String?
  browser       String?
  os            String?
  status        String    @default("PENDING")
  reviewNote    String?
  shareLink     ShareLink @relation(fields: [shareToken], references: [token], onDelete: Cascade)

  @@index([shareToken])
  @@index([status])
  @@map("unmask_requests")
}

model LinkForwardEvent {
  id                String    @id @default(uuid())
  createdAt         DateTime  @default(now())
  shareLinkId       String
  intendedRecipient String?
  intendedIp        String?
  intendedDevice    String?
  newIp             String?
  newDevice         String?
  newCountry        String?
  newCity           String?
  newBrowser        String?
  newOs             String?
  grandchildToken   String?
  action            String    @default("FLAGGED")
  shareLink         ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([shareLinkId])
  @@map("link_forward_events")
}

model FileTamperEvent {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  dnaRecordId    String
  vaultId        String
  shareToken     String?
  storedHash     String
  detectedHash   String
  accessorIp     String?
  accessorDevice String?
  linksSupended  Int      @default(0)

  @@index([dnaRecordId])
  @@map("file_tamper_events")
}

model RecipientProfile {
  id                String             @id @default(uuid())
  recipientCode     String             @unique
  fingerprint       String?            @unique
  firstSeen         DateTime           @default(now())
  lastSeen          DateTime           @default(now())
  countries         String[]           @default([])
  devices           String[]           @default([])
  ipAddresses       String[]           @default([])
  totalSessions     Int                @default(0)
  watermarkProfiles WatermarkProfile[]

  @@index([fingerprint])
  @@map("recipient_profiles")
}

model WatermarkProfile {
  id               String            @id @default(uuid())
  createdAt        DateTime          @default(now())
  dnaRecordId      String
  shareLinkId      String
  recipientId      String?
  watermarkCode    String            @unique
  watermarkVersion Int               @default(1)
  payload          String
  extractedAt      DateTime?
  extractedFrom    String?
  recipientProfile RecipientProfile? @relation(fields: [recipientId], references: [id])

  @@index([dnaRecordId])
  @@index([shareLinkId])
  @@index([watermarkCode])
  @@map("watermark_profiles")
}

model Incident {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  incidentCode    String           @unique
  dnaRecordId     String?
  shareLinkId     String?
  recipientId     String?
  severity        String
  status          String           @default("OPEN")
  triggerType     String
  description     String
  metadata        String?
  resolvedAt      DateTime?
  resolvedNote    String?
  evidenceRecords EvidenceRecord[]

  @@index([dnaRecordId])
  @@index([severity])
  @@index([status])
  @@map("incidents")
}

model EvidenceRecord {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  evidenceCode String    @unique
  incidentId   String?
  dnaRecordId  String?
  shareLinkId  String?
  recipientId  String?
  evidenceType String
  description  String
  metadata     String?
  hash         String?
  storagePath  String?
  collectedAt  DateTime  @default(now())
  ownerUserId  String?
  incident     Incident? @relation(fields: [incidentId], references: [id])
  ownerUser    User?     @relation(fields: [ownerUserId], references: [id])

  @@index([incidentId])
  @@index([dnaRecordId])
  @@map("evidence_records")
}

model ShareAccessLog {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now())
  shareLinkId        String
  recipientName      String?
  ipAddress          String?
  userAgent          String?
  browser            String?
  os                 String?
  device             String?
  country            String?
  city               String?
  region             String?
  isp                String?
  timezone           String?
  referrer           String?
  screenResolution   String?
  deviceFingerprint  String?
  riskScore          Int?
  riskLevel          String?
  riskFactors        String?
  sessionDurationSec Int?
  gpsLat             Float?
  gpsLng             Float?
  gpsAccuracy        Float?
  gpsCity            String?
  gpsTimestamp       DateTime?
  locationShared     Boolean   @default(false)
  action             String
  sessionId          String?
  asn                String?
  audioFp            String?
  canvasFp           String?
  isDatacenter       Boolean   @default(false)
  isProxy            Boolean   @default(false)
  isTor              Boolean   @default(false)
  isVpn              Boolean   @default(false)
  lat                Float?
  lng                Float?
  org                String?
  webglFp            String?
  gpsDistrict        String?
  gpsFullAddress     String?
  gpsMandal          String?
  gpsPincode         String?
  gpsState           String?
  gpsVillage         String?
  locationSource     String?
  shareLink          ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([shareLinkId])
  @@index([action])
  @@index([sessionId])
  @@map("share_access_logs")
}

enum UserRole {
  ADMIN
  ANALYST
  AUDITOR
  USER
}

enum CertStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DnaStatus {
  PENDING
  PROCESSING
  COMPLETE
  PARTIAL
  FAILED
}
