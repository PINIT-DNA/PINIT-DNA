// PINIT-DNA — Prisma Schema
// Database: PostgreSQL
// Purpose: Stores 6-layer image DNA fingerprint records

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooler — used by the running app
  directUrl = env("DIRECT_URL")     // direct — used by prisma migrate / db pull
}

// ─── Core DNA Record ──────────────────────────────────────────────────────────

model DnaRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant isolation — the user who registered this DNA record
  ownerUserId  String?
  ownerUser    User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Original file reference
  // "image" prefix kept for backward compatibility — valid for all file types
  imageFilename     String
  imageMimeType     String
  imageSizeBytes    Int
  imageWidthPx      Int?
  imageHeightPx     Int?

  // ── Universal File DNA fields (Phase 0+) ──────────────────────────────────
  // Nullable so existing IMAGE records are unaffected (treated as IMAGE engine)

  // Detected file type e.g. "IMAGE", "PDF", "DOCX"
  // NULL on legacy records means IMAGE (original engine)
  fileType          String?

  // DNA engine version e.g. "2.0.0-universal"
  // NULL on legacy records means original image-only engine "1.0.0"
  engineVersion     String?

  // Universal layer fingerprints JSON (Phase 1+: TXT/CSV/JSON/PDF/etc.)
  // Image records use the separate layer tables instead
  // Format: { layers: UniversalLayerResult[] }
  universalFingerprints Json?

  // SHA-256 of raw file bytes — used for duplicate detection across ALL file types.
  // Populated by universal-file-router (all non-image types) and dna.orchestrator (images).
  // Nullable so legacy records (pre-duplicate-check) are unaffected.
  sha256Hash        String?

  // Schema version for forward compatibility
  schemaVersion     String   @default("1.0.0")

  // Processing status
  status            DnaStatus @default(PENDING)

  // ── Layer fingerprints (one-to-one relations) ──
  cryptoLayer       CryptoLayer?
  structuralLayer   StructuralLayer?
  perceptualLayer   PerceptualLayer?
  semanticLayer     SemanticLayer?
  metadataLayer     MetadataLayer?
  stegoLayer        StegoLayer?

  // Verification history
  verifications     VerificationLog[]

  // Vault storage
  vaultRecord       VaultRecord?

  // Phase 5 — Document intelligence
  ocrRecord         OcrRecord?
  lineageFrom       DocumentLineage[] @relation("LineageFrom")
  lineageTo         DocumentLineage[] @relation("LineageTo")

  // Crawler/Monitoring
  monitorRecords    MonitorRecord[]

  @@map("dna_records")
}

// ─── Layer 1: SHA-256 Cryptographic Hash ─────────────────────────────────────

model CryptoLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // SHA-256 of the raw image bytes
  sha256Hash  String    @db.Char(64)

  // SHA-256 of the normalized image bytes (strips EXIF, re-encodes) for
  // content-identical matching across saves
  normalizedHash String @db.Char(64)

  // BLAKE3 hash for future-proof secondary verification (placeholder)
  blake3Hash  String?   @db.Char(64)

  @@map("crypto_layers")
}

// ─── Layer 2: Structural Fingerprint (edge-based) ─────────────────────────────

model StructuralLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Canny edge map serialized as base64 PNG thumbnail
  edgeMapB64       String   @db.Text

  // Dominant structural vectors (JSON array of {angle, magnitude})
  edgeVectors      Json

  // 64-bit compact edge signature for fast comparison
  edgeSignature64  String   @db.Char(16)

  // Algorithm used (e.g. "canny", "sobel")
  algorithm        String   @default("canny")

  @@map("structural_layers")
}

// ─── Layer 3: Perceptual Visual Hash (pHash) ─────────────────────────────────

model PerceptualLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // 64-bit DCT-based perceptual hash (hex string)
  pHash64     String    @db.Char(16)

  // 256-bit extended pHash for high-precision matching
  pHash256    String    @db.Char(64)

  // Average hash for fast pre-filter
  aHash64     String    @db.Char(16)

  // Difference hash
  dHash64     String    @db.Char(16)

  @@map("perceptual_layers")
}

// ─── Layer 4: Semantic Color Fingerprint (RGB histogram) ─────────────────────

model SemanticLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // 256-bin RGB histograms (JSON arrays)
  histogramR  Json
  histogramG  Json
  histogramB  Json

  // HSV histogram for hue-dominant matching
  histogramH  Json
  histogramS  Json

  // Dominant colors — top 5 hex codes + percentage coverage
  dominantColors Json

  // Compact 48-bit color fingerprint (hex)
  colorFingerprint String @db.Char(12)

  @@map("semantic_layers")
}

// ─── Layer 5: Metadata Provenance Record ─────────────────────────────────────

model MetadataLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Raw EXIF extracted as JSON (null if none present)
  exifData    Json?

  // Camera/device fingerprint (make, model, software)
  deviceMake    String?
  deviceModel   String?
  software      String?

  // Capture datetime from EXIF (may differ from upload time)
  capturedAt    DateTime?

  // GPS coordinates if present
  gpsLatitude   Float?
  gpsLongitude  Float?

  // IPTC / XMP fields
  iptcData      Json?
  xmpData       Json?

  // Hash of the metadata block (for tamper detection)
  metadataHash  String   @db.Char(64)

  @@map("metadata_layers")
}

// ─── Layer 6: Hidden AI Signature (LSB Steganography) ────────────────────────

model StegoLayer {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Whether the signature was successfully embedded
  embedded     Boolean  @default(false)

  // Capacity in bits available in the carrier image
  capacityBits Int?

  // Bits actually used
  usedBits     Int?

  // HMAC of the embedded payload (used during extraction + verification)
  payloadHmac  String   @db.Char(64)

  // LSB channel used: "R", "G", "B", or "alpha"
  channel      String   @default("B")

  // Base image path where signature was embedded (relative to storage root)
  carrierPath  String?

  @@map("stego_layers")
}

// ─── Verification Log ────────────────────────────────────────────────────────

model VerificationLog {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Overall result
  passed      Boolean

  // Per-layer results (JSON object, keyed by layer name)
  layerResults Json

  // Similarity scores per layer (0.0–1.0)
  similarityScores Json

  // Overall confidence score (0.0–1.0)
  confidenceScore Float

  // Which layers were checked
  layersChecked   String[]

  // Client IP (for audit trail)
  requestIp     String?

  @@map("verification_logs")
}

// ─── Vault Record ─────────────────────────────────────────────────────────────

model VaultRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Link to the DNA record this vault entry protects
  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  // Encrypted file on disk — NEVER the original image
  encryptedFilePath   String
  originalFileName    String
  originalMimeType    String
  encryptedSizeBytes  Int
  originalSizeBytes   Int

  // Encryption metadata (key is never stored — derived via HKDF at retrieval)
  encryptionAlgorithm String  @default("AES-256-GCM")
  keyDerivation       String  @default("HKDF-SHA256")
  ivHex               String  @db.Char(24)   // 12-byte IV = 24 hex chars
  authTagHex          String  @db.Char(32)   // 16-byte auth tag = 32 hex chars

  @@map("vault_records")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Short human-readable login ID, e.g. "PINIT-A7K2M9X4"
  shortId      String    @unique

  // Optional — not required for login
  email        String?   @unique
  passwordHash String?
  fullName     String    @default("PINIT User")
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  refreshTokens    RefreshToken[]
  dnaRecords       DnaRecord[]
  shareLinks       ShareLink[]
  shareRecipients  ShareRecipient[]
  monitorRecords   MonitorRecord[]
  certificates     Certificate[]
  evidenceRecords  EvidenceRecord[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@map("refresh_tokens")
}

// ─── Certificates (Phase 2 hardening) ────────────────────────────────────────

model Certificate {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  certificateId    String   @unique
  dnaRecordId      String
  vaultId          String
  status           CertStatus @default(ACTIVE)
  signature        String   @db.Text
  issuedAt         DateTime @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  issuedByUserId   String?

  // Tenant isolation
  ownerUserId      String?
  ownerUser        User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([dnaRecordId])
  @@index([vaultId])
  @@map("certificates")
}

// ─── OCR & Semantic Data ──────────────────────────────────────────────────────

model OcrRecord {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  dnaRecordId String    @unique
  dnaRecord   DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  extractedText String?  @db.Text
  wordCount     Int      @default(0)
  confidence    Float    @default(0)
  language      String   @default("eng")
  processingMs  Int      @default(0)
  indexed       Boolean  @default(false)
  ocrStatus     String   @default("PENDING")  // PENDING | PROCESSING | COMPLETE | FAILED
  errorMessage  String?

  @@map("ocr_records")
}

// ─── Document Lineage ─────────────────────────────────────────────────────────

model DocumentLineage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  fromDnaRecordId String
  toDnaRecordId   String
  relation        String   // DUPLICATE | DERIVED_FROM | RELATED | MODIFIED_COPY
  confidence      Float

  fromDnaRecord DnaRecord @relation("LineageFrom", fields: [fromDnaRecordId], references: [id], onDelete: Cascade)
  toDnaRecord   DnaRecord @relation("LineageTo",   fields: [toDnaRecordId],   references: [id], onDelete: Cascade)

  @@unique([fromDnaRecordId, toDnaRecordId])
  @@map("document_lineage")
}

// ─── Audit Events ─────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventType   String
  userId      String?
  dnaRecordId String?
  vaultId     String?
  filename    String?
  fileType    String?
  ipAddress   String?
  userAgent   String?  @db.Text
  browser     String?
  os          String?
  device      String?
  detail      Json?

  @@index([dnaRecordId])
  @@index([eventType])
  @@index([createdAt])
  @@map("audit_events")
}

// ─── Crawler & Monitoring ─────────────────────────────────────────────────────

model MonitorRecord {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Tenant isolation
  ownerUserId   String?
  ownerUser     User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  dnaRecordId   String
  dnaRecord     DnaRecord @relation(fields: [dnaRecordId], references: [id], onDelete: Cascade)

  filename      String
  fileType      String    @default("UNKNOWN")
  status        String    @default("ACTIVE")    // ACTIVE | PAUSED | STOPPED
  scanType      String    @default("DAILY")     // MANUAL | DAILY | WEEKLY | CONTINUOUS
  checkEveryHrs Int       @default(24)
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  totalChecks   Int       @default(0)
  totalMatches  Int       @default(0)
  totalFailures Int       @default(0)
  lastDurationMs Int?

  watchUrls     String[]
  crawlResults  CrawlResult[]
  monitoringRuns MonitoringRun[]

  @@index([status])
  @@index([nextCheckAt])
  @@map("monitor_records")
}

model CrawlResult {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())

  monitorRecordId String
  monitorRecord   MonitorRecord @relation(fields: [monitorRecordId], references: [id], onDelete: Cascade)

  url             String        @db.Text
  pageTitle       String?
  foundText       String?       @db.Text
  textLength      Int           @default(0)
  similarity      Float         @default(0)
  matchType       String        @default("NO_MATCH") // EXACT_MATCH | HIGH_MATCH | POSSIBLE_MATCH | NO_MATCH
  alertStatus     String        @default("PENDING")  // PENDING | CONFIRMED | DISMISSED
  checkedAt       DateTime      @default(now())
  evidenceGenerated Boolean     @default(false)
  contentSnapshot String?       @db.Text
  screenshotPath  String?

  @@index([monitorRecordId])
  @@index([matchType])
  @@index([alertStatus])
  @@map("crawl_results")
}

model MonitoringRun {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())

  monitorRecordId String
  monitorRecord   MonitorRecord @relation(fields: [monitorRecordId], references: [id], onDelete: Cascade)

  status          String        @default("RUNNING")  // RUNNING | COMPLETED | FAILED
  trigger         String        @default("SCHEDULED") // SCHEDULED | MANUAL | CONTINUOUS
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  durationMs      Int?
  candidatesFound Int           @default(0)
  matchesFound    Int           @default(0)
  failureReason   String?

  failures        MonitoringFailure[]

  @@index([monitorRecordId])
  @@index([status])
  @@map("monitoring_runs")
}

model MonitoringFailure {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())

  monitoringRunId String
  monitoringRun   MonitoringRun @relation(fields: [monitoringRunId], references: [id], onDelete: Cascade)

  url             String        @db.Text
  errorCode       String?
  errorMessage    String?       @db.Text
  stage           String?       // CRAWL | DOWNLOAD | FINGERPRINT | COMPARE

  @@index([monitoringRunId])
  @@map("monitoring_failures")
}

// ─── Smart Links Engine ───────────────────────────────────────────────────────

model ShareLink {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tenant isolation
  ownerUserId  String?
  ownerUser    User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  // What is being shared
  vaultId     String
  dnaRecordId String
  filename    String
  mimeType    String   @default("application/octet-stream")

  // Unique public token (used in URL: /s/:token)
  token       String   @unique

  // Access policies
  expiresAt   DateTime?        // null = never expires
  maxViews    Int?              // null = unlimited
  viewCount   Int      @default(0)
  isActive    Boolean  @default(true)
  allowDownload Boolean @default(false)
  requireName  Boolean @default(false)  // recipient must enter name
  note         String?  @db.Text        // optional note to recipient

  // ── Extended access policy (Phase: Access Policies / Access Control Matrix)
  oneTimeUse        Boolean  @default(false) // link self-revokes after first VIEWED
  maxDownloads      Int?                      // null = governed by allowDownload only
  downloadCount     Int      @default(0)
  allowedCountries  String[] @default([])     // empty = no restriction (allow-list of ISO country names)
  allowedDeviceTypes String[] @default([])    // empty = no restriction (desktop|mobile|tablet)
  allowedIpPrefixes String[] @default([])     // empty = no restriction (CIDR-ish prefixes, e.g. "203.0.113")

  // ── Identity verification (Phase: Access Policies — Email/OTP gate) ───────
  requireOtp     Boolean  @default(false)
  recipientEmail String?
  otpCodeHash    String?                       // sha256(otp) — never store plaintext
  otpExpiresAt   DateTime?
  otpVerified    Boolean  @default(false)

  // ── Integrity (Phase: Smart Link Generation — HMAC signature) ─────────────
  tokenSignature String?

  // ── Privacy Masking (viewer-layer only — original file NEVER modified) ────
  privacyMaskingEnabled Boolean  @default(false)
  maskEmail             Boolean  @default(false)
  maskPhone             Boolean  @default(false)
  maskAadhaar           Boolean  @default(false)
  maskPan               Boolean  @default(false)
  maskAddress           Boolean  @default(false)
  maskCustomPatterns    String?  // JSON array of custom regex strings

  // ── GPS Location Request ──────────────────────────────────────────────────
  requestLocation  Boolean  @default(false)  // ask recipient for GPS permission

  // ── Link Hierarchy (Parent → Child → Grandchild chain) ───────────────────
  linkType      String   @default("PARENT")  // PARENT | CHILD | GRANDCHILD
  parentLinkId  String?                       // null for parent links
  parentLink    ShareLink?  @relation("LinkHierarchy", fields: [parentLinkId], references: [id], onDelete: SetNull)
  childLinks    ShareLink[] @relation("LinkHierarchy")
  depth         Int      @default(0)          // 0=parent, 1=child, 2=grandchild

  // ── Per-recipient tracking ────────────────────────────────────────────────
  recipientLabel            String?
  intendedIpAddress         String?
  intendedDeviceFingerprint String?
  forwardingDetected        Boolean @default(false)
  forwardedByLabel          String?

  // ── Enterprise Security Controls ──────────────────────────────────────────
  oneDeviceOnly         Boolean  @default(false)
  oneIpOnly             Boolean  @default(false)
  vpnBlock              Boolean  @default(false)
  torBlock              Boolean  @default(true)
  firstViewExpiresAfter Int?
  domainRestrictions    String[] @default([])
  corporateIpRanges     String[] @default([])

  // ── Forensic recipient binding ─────────────────────────────────────────────
  shareRecipientId  String?
  shareRecipient    ShareRecipient? @relation(fields: [shareRecipientId], references: [id], onDelete: SetNull)
  watermarkCode     String?
  forwardRiskScore  Int     @default(0)
  forwardConfidence Int     @default(0)
  forwardStatus     String  @default("CLEAN")

  // Relations
  accessLogs      ShareAccessLog[]
  unmaskRequests  UnmaskRequest[]
  forwardEvents   LinkForwardEvent[]

  @@index([token])
  @@index([vaultId])
  @@index([dnaRecordId])
  @@index([parentLinkId])
  @@index([shareRecipientId])
  @@index([forwardStatus])
  @@map("share_links")
}

// ─── Forensic Recipient ───────────────────────────────────────────────────────

model ShareRecipient {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerUserId   String
  ownerUser     User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  label         String
  recipientCode String   @unique
  trustScore    Int      @default(100)

  knownDevices     String[] @default([])
  knownIps         String[] @default([])
  knownCountries   String[] @default([])
  totalAccessCount Int      @default(0)
  lastAccessAt     DateTime?
  firstAccessAt    DateTime?

  shareLinks  ShareLink[]
  trustEvents RecipientTrustEvent[]

  @@index([ownerUserId])
  @@index([recipientCode])
  @@map("share_recipients")
}

// ─── Recipient Trust Score History ───────────────────────────────────────────

model RecipientTrustEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  recipientId String
  recipient   ShareRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  eventType   String
  scoreBefore Int
  scoreAfter  Int
  delta       Int
  reason      String
  linkId      String?

  @@index([recipientId])
  @@map("recipient_trust_events")
}

// ─── Privacy Masking — Unmask Access Requests ────────────────────────────────

model UnmaskRequest {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  shareToken    String
  shareLink     ShareLink @relation(fields: [shareToken], references: [token], onDelete: Cascade)

  recipientName String?
  sessionId     String?
  ipAddress     String?
  device        String?
  browser       String?
  os            String?

  // PENDING | APPROVED | REJECTED
  status        String    @default("PENDING")
  reviewNote    String?   // owner's optional note on decision

  @@index([shareToken])
  @@index([status])
  @@map("unmask_requests")
}

// ─── Link Forwarding Detection ───────────────────────────────────────────────

model LinkForwardEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  shareLinkId       String
  shareLink         ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  // Who was supposed to access
  intendedRecipient String?   // recipientLabel of the child link
  intendedIp        String?
  intendedDevice    String?

  // Who actually accessed (the forwarder's recipient)
  newIp             String?
  newDevice         String?
  newCountry        String?
  newCity           String?
  newBrowser        String?
  newOs             String?

  // Auto-created grandchild link token
  grandchildToken   String?

  // Action taken
  action            String    @default("FLAGGED") // FLAGGED | BLOCKED | ALLOWED

  @@index([shareLinkId])
  @@map("link_forward_events")
}

// ─── File Tamper Events ───────────────────────────────────────────────────────

model FileTamperEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  dnaRecordId   String
  vaultId       String
  shareToken    String?   // which share link triggered the detection

  storedHash    String    // original SHA-256 from DNA record
  detectedHash  String    // hash computed at serve time
  accessorIp    String?
  accessorDevice String?

  // All child links suspended as a result
  linksSupended  Int      @default(0)

  @@index([dnaRecordId])
  @@map("file_tamper_events")
}

// ─── Phase 2: Recipient Identity System ──────────────────────────────────────

model RecipientProfile {
  id            String   @id @default(uuid())
  recipientCode String   @unique  // REC-001, REC-002, ...
  fingerprint   String?  @unique  // device fingerprint hash for re-identification
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @default(now())
  countries     String[] @default([])
  devices       String[] @default([])
  ipAddresses   String[] @default([])
  totalSessions Int      @default(0)

  watermarkProfiles WatermarkProfile[]

  @@index([fingerprint])
  @@map("recipient_profiles")
}

// ─── Phase 2: Watermark Profiles ─────────────────────────────────────────────

model WatermarkProfile {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())

  dnaRecordId      String
  shareLinkId      String
  recipientId      String?
  recipientProfile RecipientProfile? @relation(fields: [recipientId], references: [id])

  watermarkCode    String   @unique  // WM-XXXX-YYYY
  watermarkVersion Int      @default(1)
  payload          String   @db.Text // JSON: {mfid, shareId, recipientId, timestamp, wmCode}

  // Extraction status (set when leak scan finds this watermark)
  extractedAt      DateTime?
  extractedFrom    String?   // path/description of leaked file

  @@index([dnaRecordId])
  @@index([shareLinkId])
  @@index([watermarkCode])
  @@map("watermark_profiles")
}

// ─── Phase 2: Incidents ───────────────────────────────────────────────────────

model Incident {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidentCode String  @unique  // INC-0001
  dnaRecordId  String?
  shareLinkId  String?
  recipientId  String?

  severity     String   // LOW | MEDIUM | HIGH | CRITICAL
  status       String   @default("OPEN")  // OPEN | INVESTIGATING | RESOLVED | DISMISSED
  triggerType  String   // SCREENSHOT_BURST | LEAK_MATCH | COUNTRY_VIOLATION | MASS_DOWNLOAD | VPN_DETECTED | MANUAL
  description  String   @db.Text
  metadata     String?  @db.Text  // JSON: extra context

  resolvedAt   DateTime?
  resolvedNote String?  @db.Text

  evidenceRecords EvidenceRecord[]

  @@index([dnaRecordId])
  @@index([severity])
  @@index([status])
  @@map("incidents")
}

// ─── Phase 2: Evidence Records ────────────────────────────────────────────────

model EvidenceRecord {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())

  evidenceCode String   @unique  // EVD-0001
  incidentId   String?
  incident     Incident? @relation(fields: [incidentId], references: [id])

  // Tenant isolation
  ownerUserId  String?
  ownerUser    User?    @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  dnaRecordId  String?
  shareLinkId  String?
  recipientId  String?

  evidenceType String   // WATERMARK_MATCH | ACCESS_LOG | VIOLATION | LEAK_ATTRIBUTION | MANUAL
  description  String   @db.Text
  metadata     String?  @db.Text  // JSON: structured evidence data
  hash         String?  // SHA-256 of evidence content (integrity)
  storagePath  String?  // path to stored evidence file if any

  collectedAt  DateTime @default(now())

  @@index([incidentId])
  @@index([dnaRecordId])
  @@map("evidence_records")
}

model ShareAccessLog {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())

  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  // Who accessed
  recipientName String?  // if requireName = true
  ipAddress   String?
  userAgent   String?   @db.Text
  browser     String?
  os          String?
  device      String?   // desktop | mobile | tablet
  country     String?
  city        String?
  region      String?   // ── Geo Intelligence: now persisted (was fetched but dropped)
  isp         String?   // ── Geo Intelligence: ISP / org name from ip-api.com
  timezone    String?
  referrer    String?   @db.Text

  // ── Device Fingerprinting extensions ──────────────────────────────────────
  screenResolution String?  // "1920x1080" — sent by client
  deviceFingerprint String? // sha256 hash of canvas+webgl+fonts signature

  // ── Forensic IP Intelligence ──────────────────────────────────────────────
  isVpn         Boolean  @default(false)
  isTor         Boolean  @default(false)
  isProxy       Boolean  @default(false)
  isDatacenter  Boolean  @default(false)
  asn           String?
  org           String?
  lat           Float?
  lng           Float?
  canvasFp      String?
  webglFp       String?
  audioFp       String?

  // ── AI Risk Engine — computed at write-time from event + context history ──
  riskScore   Int?      // 0-100
  riskLevel   String?   // LOW | MEDIUM | HIGH | CRITICAL
  riskFactors String?   @db.Text // JSON array of human-readable reasons

  // ── Session Monitoring — duration of the session this event belongs to ────
  sessionDurationSec Int?

  // ── GPS Location (optional — user consent required) ───────────────────────
  gpsLat        Float?    // latitude  (null if denied / not requested)
  gpsLng        Float?    // longitude
  gpsAccuracy   Float?    // accuracy radius in metres
  gpsCity       String?   // reverse-geocoded city name
  gpsTimestamp  DateTime? // when the browser captured the position
  locationShared Boolean  @default(false) // true=allowed, false=denied/skipped

  // What happened
  action      String    // VIEWED | DOWNLOADED | BLOCKED_* | COPY_ATTEMPT | SCREENSHOT_ATTEMPT | ...
  sessionId   String?   // groups events in one visit

  @@index([shareLinkId])
  @@index([action])
  @@index([sessionId])
  @@map("share_access_logs")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ANALYST
  AUDITOR
  USER
}

enum CertStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DnaStatus {
  PENDING      // Upload received, processing not started
  PROCESSING   // Fingerprint generation in progress
  COMPLETE     // All 6 layers generated successfully
  PARTIAL      // Some layers failed; partial DNA stored
  FAILED       // Generation failed entirely
}
