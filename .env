# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development

PORT=4000
API_PREFIX=/api/v1

# ─── Apache Tika ──────────────────────────────────────────────────────────────
TIKA_URL=http://localhost:9998

# ─── Database ─────────────────────────────────────────────────────────────────
# Replace with your runtime DB connection (do NOT commit real credentials)
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:6543/<DB>?pgbouncer=true"

DIRECT_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DB>"

# ─── File Storage ─────────────────────────────────────────────────────────────
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff
# Max upload size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
# Temp directory for uploaded files before processing
UPLOAD_TEMP_DIR=./tmp/uploads

# ─── DNA Generation ───────────────────────────────────────────────────────────
DNA_SCHEMA_VERSION=1.0.0

# ─── Layer 6 — LSB Steganography ──────────────────────────────────────────────
# Secret used to generate the hidden AI signature payload (rotate in prod)
LSB_SIGNATURE_SECRET=REPLACE_ME_LSB_SIGNATURE_SECRET

# ─── Vault Storage ────────────────────────────────────────────────────────────
VAULT_MASTER_SECRET=REPLACE_ME_VAULT_MASTER_SECRET
VAULT_STORAGE_DIR=./vault/encrypted

# ─── Supabase Storage (vault file persistence) ────────────────────────────────
# Replace with your Supabase project URL
SUPABASE_URL=https://<your-supabase-project>.supabase.co
# Service key placeholder (do NOT store real service keys here)
SUPABASE_SERVICE_KEY=REPLACE_ME_SUPABASE_SERVICE_KEY

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Smart Links — Public App URL ─────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:3000

SHARE_HMAC_SECRET=REPLACE_ME_SHARE_HMAC_SECRET

# ─── Image Monitoring ────────────────────────────────────────────────────────
# BING_SEARCH_API_KEY=REPLACE_ME_BING_SEARCH_API_KEY
# ─── Server ───────────────────────────────────────────────────────────────────
