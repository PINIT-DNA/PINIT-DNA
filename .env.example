# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development

PORT=4000
API_PREFIX=/api/v1

# ─── Apache Tika ──────────────────────────────────────────────────────────────
TIKA_URL=http://localhost:9998

# ─── Database ─────────────────────────────────────────────────────────────────
# Company Supabase (kqdqmimdqecensurjplh) — URL-encode special chars in password (@ → %40)
DATABASE_URL="postgresql://postgres.kqdqmimdqecensurjplh:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.kqdqmimdqecensurjplh:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Allowed MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff
# Max upload size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
# Temp directory for uploaded files before processing
UPLOAD_TEMP_DIR=./tmp/uploads

# ─── DNA Generation ───────────────────────────────────────────────────────────
# Version tag stamped into every DNA record
DNA_SCHEMA_VERSION=1.0.0

# ─── Layer 6 — LSB Steganography ──────────────────────────────────────────────
# Secret used to generate the hidden AI signature payload
# ROTATE THIS IN PRODUCTION — treat like a signing key
LSB_SIGNATURE_SECRET=change_me_in_production

# ─── TEP v3.0 — Tracked Export Package signing ────────────────────────────────
# Signs per-recipient download manifests; falls back to LSB_SIGNATURE_SECRET
TEP_SIGNING_SECRET=change_me_in_production_tep
# Embed TEP tracking on Protected Download (owner vault export) — default true
TEP_PROTECTED_DOWNLOAD_ENABLED=true

# ─── Vault Storage ────────────────────────────────────────────────────────────
VAULT_MASTER_SECRET=change_me_in_production
VAULT_STORAGE_DIR=./vault/encrypted

# ─── Supabase Storage (vault file persistence) ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Smart Links — Public App URL ─────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:3000

SHARE_HMAC_SECRET=change_me_in_production

# ─── Enterprise Biometric Auth ─────────────────────────────────────────────────
# Separate key for encrypting face/voice/fingerprint templates at rest
BIOMETRIC_ENCRYPTION_KEY=change_me_in_production_use_32_plus_chars
# Optional tuning (defaults shown)
# BIOMETRIC_FACE_LOGIN_THRESHOLD=0.62
# BIOMETRIC_FACE_DUPLICATE_THRESHOLD=0.42
# BIOMETRIC_FUSION_MIN_CONFIDENCE=72

# ─── Image Monitoring (optional — not used for Verify Leaked File) ───────────
# MONITORING_CRAWLER_ENABLED=false
# BING_SEARCH_API_KEY=your_key_here

# INVISIBLE_WATERMARK_EMBEDDING_ENABLED=false
# DNA_ENHANCEMENTS_ENABLED=false
# DNA_L1_BLAKE3=true
# DNA_L1_SHA3_512=true
# DNA_L1_CHUNK_HASH=true
# DNA_L2_MULTI_SCALE=true
# DNA_L3_BM_HASH=true
# DNA_L3_WAVELET_HASH=true
# DNA_L4_LAB=true
# DNA_VERIFY_WEIGHTED=true
# DNA_VERIFY_TAMPER_CLASS=true
# DNA_L11_CLIP=false

# ─── DNA Engine Phase 2 (v2.2 — requires DNA_ENHANCEMENTS_ENABLED=true) ─────
# DNA_PHASE2_ENABLED=false
# DNA_P2_OCR=true
# DNA_P2_VIDEO=true
# DNA_P2_AUDIO=true
# DNA_P2_SCREENSHOT=true
# DNA_P2_SCREEN_RECORD=true
# DNA_P2_ADAPTIVE_SCORE=true
# DNA_P2_EXPLANATION=true
# DNA_P2_EVIDENCE=true
# DNA_P2_SELF_LEARNING=false
# DNA_P2_TRANSFORM_HISTORY=true
# DNA_P2_CROSS_MEDIA=true
# DNA_P2_LIGHTWEIGHT_API=true
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe
# FPCALC_PATH=fpcalc

# ─── DNA Engine Phase 3 (v2.3 — Watermark & Evidence, OFF by default) ────────
# DNA_PHASE3_ENABLED=false
# DNA_P3_PROTECTED_DOWNLOAD_TOKEN=true
# DNA_P3_WATERMARK_EMBED=true
# DNA_P3_WATERMARK_RECOVERY=true
# DNA_P3_SIGNED_REPORTS=true
# DNA_P3_EVIDENCE_PACKAGE=true
# DNA_P3_VAULT_WATERMARK=true
# INVISIBLE_WATERMARK_EMBEDDING_ENABLED=false
# PHASE3_SIGNING_SECRET=change_me_in_production
# PHASE3_ED25519_PRIVATE_KEY_PEM=

# ─── Protected Download (ON by default) ───────────────────────────────────────
# PROTECTED_DOWNLOAD_ENABLED=true

# ─── Python AI sidecar (auto-started by npm run dev → Node 4000 → Python 8001) ─
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://localhost:8001
# Install deps once: cd python-ai && pip install -r requirements.txt
# Production (Render): set AI_SERVICE_URL to your Hugging Face / external AI URL only
