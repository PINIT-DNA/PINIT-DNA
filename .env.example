# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development

PORT=4000
API_PREFIX=/api/v1

# ─── Apache Tika ──────────────────────────────────────────────────────────────
TIKA_URL=http://localhost:9998

# ─── Database ─────────────────────────────────────────────────────────────────
# Used by Prisma at RUNTIME (app queries) — Transaction Pooler, port 6543
DATABASE_URL="postgresql://postgres.ogvbrncyheigcbbzleeg:Ashwithareddy2004@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.ogvbrncyheigcbbzleeg:Ashwithareddy2004@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Allowed MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff
# Max upload size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
# Temp directory for uploaded files before processing
UPLOAD_TEMP_DIR=./tmp/uploads

# ─── DNA Generation ───────────────────────────────────────────────────────────
# Version tag stamped into every DNA record
DNA_SCHEMA_VERSION=1.0.0

# ─── Layer 6 — LSB Steganography ──────────────────────────────────────────────
# Secret used to generate the hidden AI signature payload
# ROTATE THIS IN PRODUCTION — treat like a signing key
LSB_SIGNATURE_SECRET=change_me_in_production

# ─── Vault Storage ────────────────────────────────────────────────────────────
VAULT_MASTER_SECRET=PinitDNA_Vault_Master_Secret_2024
VAULT_STORAGE_DIR=./vault/encrypted

