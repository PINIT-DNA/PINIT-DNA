# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/pinit_dna?schema=public"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Allowed MIME types (comma-separated)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/tiff
# Max upload size in bytes (default: 20MB)
MAX_FILE_SIZE=20971520
# Temp directory for uploaded files before processing
UPLOAD_TEMP_DIR=./tmp/uploads

# ─── DNA Generation ───────────────────────────────────────────────────────────
# Version tag stamped into every DNA record
DNA_SCHEMA_VERSION=1.0.0

# ─── Layer 6 — LSB Steganography ──────────────────────────────────────────────
# Secret used to generate the hidden AI signature payload
# ROTATE THIS IN PRODUCTION — treat like a signing key
LSB_SIGNATURE_SECRET=change_me_in_production

# ─── Vault Storage ────────────────────────────────────────────────────────────
# Master secret used to derive per-vault AES-256 keys via HKDF
# NEVER store the derived keys — only this master secret
# Treat like a private key — rotate periodically in production
VAULT_MASTER_SECRET=change_me_vault_secret_in_production
# Directory where encrypted vault files are stored
VAULT_STORAGE_DIR=./vault/encrypted

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
